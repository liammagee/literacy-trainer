# Required: your Anthropic API key. The server uses this for every Claude call;
# clients never see it.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default Claude model (any current Anthropic model id).
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: bind address and port. Defaults shown.
# HOST=127.0.0.1
# PORT=8765

# Optional: where SQLite + uploaded PDFs live. Default: ./data
# DATA_DIR=./data
